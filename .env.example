# 应用配置
APP_NAME=NexusFlow
DEBUG=True

# 服务器配置
HOST=0.0.0.0
PORT=8000

# CORS 配置
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./nexusflow.db

# AI 服务配置（设置为 "mock" 启用模拟模式）
USE_MOCK_MODE=True
AI_API_KEY=mock
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-3.5-turbo

# 日志配置
LOG_LEVEL=INFO
